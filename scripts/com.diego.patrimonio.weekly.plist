<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.diego.patrimonio.weekly</string>
  <key>ProgramArguments</key>
  <array>
    <string>PROJECT_DIR/.venv/bin/python</string>
    <string>-m</string>
    <string>src.patrimonio.cli</string>
    <string>run</string>
  </array>
  <key>WorkingDirectory</key>
  <string>PROJECT_DIR</string>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>0</integer>
    <key>Hour</key>
    <integer>22</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>PROJECT_DIR/logs/patrimonio.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>PROJECT_DIR/logs/patrimonio.stderr.log</string>
</dict>
</plist>
