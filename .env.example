TG_BOT_TOKEN=
TG_CHAT_ID=
ANTHROPIC_API_KEY=
DRY_RUN=false
HEADLESS=false
LOG_LEVEL=INFO
DB_PATH=data/banco.db
GSHEET_KEY_PATH=data/gsheet_service_account.json

# ── Feature: Movimientos (revisión masiva en dashboard) ──
# Si está en "true", el bot levanta la API HTTP en el mismo proceso (puerto $PORT,
# default 8080). El dashboard Next.js le pega vía DASHBOARD_API_TOKEN.
ENABLE_MOVIMIENTOS_REVIEW=false
DASHBOARD_API_TOKEN=
DASHBOARD_ORIGIN=
PORT=8080
